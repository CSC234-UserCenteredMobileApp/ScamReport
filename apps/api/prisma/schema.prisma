// Prisma schema for the Scam Report Platform.
//
// See DATABASE_DESIGN.md (repo root) for the canonical design rationale.
//
// v7 notes:
// - The runtime URL (pooled — DATABASE_URL) is supplied to PrismaClient via
//   the @prisma/adapter-pg driver in src/core/db/client.ts.
// - The migration URL (direct — DIRECT_URL) is set in prisma.config.ts.
//
// What this schema models vs. what lives in raw SQL (migration.sql):
// - Models, enums, FK relations, basic indexes  → here.
// - Postgres extensions, citext (via @db.Citext), inet (via @db.Inet)  → here.
// - vector(768) embedding column                → Unsupported() here, real
//                                                  type in raw SQL.
// - Partial / functional / ivfflat indexes      → raw SQL.
// - Triggers (updated_at, status sync, push enqueue, ≤5 evidence files)  → raw SQL.
// - RLS policies + current_firebase_uid() helper → raw SQL.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums — mapped to lowercase Postgres enum types (see DATABASE_DESIGN.md §3)
// =============================================================================

enum UserRole {
  user
  admin

  @@map("user_role")
}

enum PreferredLang {
  th
  en

  @@map("preferred_lang")
}

enum ReportStatus {
  pending
  verified
  rejected
  flagged
  withdrawn

  @@map("report_status")
}

enum IdentifierKind {
  phone
  url
  other

  @@map("identifier_kind")
}

enum EvidenceKind {
  image
  pdf

  @@map("evidence_kind")
}

enum ModerationActionKind {
  approve
  reject
  flag
  unflag

  @@map("moderation_action")
}

enum VerdictLabel {
  scam
  suspicious
  safe
  unknown

  @@map("verdict_label")
}

enum CheckInputKind {
  phone
  url
  text

  @@map("check_input_kind")
}

enum AnnouncementCategory {
  fraud_alert
  tips
  platform_update

  @@map("announcement_cat")
}

enum AnnouncementStatus {
  draft
  published
  unpublished

  @@map("announcement_stat")
}

enum ConsentKind {
  registration
  first_report_submission
  privacy_policy
  terms_of_service

  @@map("consent_kind")
}

enum NotificationKind {
  report_verified
  report_rejected
  report_flagged

  @@map("notification_kind")
}

enum DevicePlatform {
  ios
  android
  web

  @@map("device_platform")
}

enum ScammerRiskLevel {
  low
  medium
  high
  unknown

  @@map("scammer_risk_level")
}

enum ScammerIdentifierKind {
  phone
  url
  email
  bank_account
  line_id
  social_handle
  other

  @@map("scammer_identifier_kind")
}

// =============================================================================
// Tables
// =============================================================================

/// Internal user profile — one row per Firebase account. (DESIGN §4.1)
model User {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebaseUid       String        @unique @map("firebase_uid")
  email             String?       @unique @db.Citext
  displayName       String?       @map("display_name")
  role              UserRole      @default(user)
  preferredLanguage PreferredLang @default(th) @map("preferred_language")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime      @default(now()) @map("updated_at") @db.Timestamptz()
  deletedAt         DateTime?     @map("deleted_at") @db.Timestamptz()

  consents        ConsentRecord[]
  reports         Report[]
  moderations     ModerationAction[]
  announcements   Announcement[]
  fcmDevices      FcmDevice[]
  notifications   Notification[]
  aiConversations AiConversation[]
  checkLogs       CheckLog[]
  @@index([role])
  @@map("users")
}

/// Append-only PDPA consent log. (DESIGN §4.2)
model ConsentRecord {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?     @map("user_id") @db.Uuid
  consentType   ConsentKind @map("consent_type")
  policyVersion String      @map("policy_version")
  acceptedAt    DateTime    @default(now()) @map("accepted_at") @db.Timestamptz()
  ipAddress     String?     @map("ip_address") @db.Inet
  userAgent     String?     @map("user_agent")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("consent_records")
}

/// Reference taxonomy for scam categories. (DESIGN §4.3)
model ScamType {
  id           Int     @id @db.SmallInt
  code         String  @unique
  labelEn      String  @map("label_en")
  labelTh      String  @map("label_th")
  isActive     Boolean @default(true) @map("is_active")
  displayOrder Int     @default(0) @map("display_order") @db.SmallInt

  reports Report[]

  @@map("scam_types")
}

/// The central content table. (DESIGN §4.4)
model Report {
  id                         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId                 String?         @map("reporter_id") @db.Uuid
  title                      String
  description                String
  scamTypeId                 Int             @map("scam_type_id") @db.SmallInt
  targetIdentifier           String?         @map("target_identifier")
  targetIdentifierKind       IdentifierKind? @map("target_identifier_kind")
  targetIdentifierNormalized String?         @map("target_identifier_normalized") @db.Citext
  status                     ReportStatus    @default(pending)
  priorityFlag               Boolean         @default(false) @map("priority_flag")
  rejectionRemark            String?         @map("rejection_remark")
  /// AI similarity score (0..100), persisted at submit time. Null when
  /// embedding failed or no verified embeddings exist yet. See
  /// `apps/api/src/core/ai-score/index.ts`.
  aiScore                    Int?            @map("ai_score")
  /// AI confidence tier: 'high' | 'medium' | 'low' | 'unknown'. See
  /// `packages/shared/src/schemas/admin-reports.ts` for the union.
  aiConfidence               String?         @map("ai_confidence")
  /// Name the reporter or Ask AI attributed to the caller/sender at submit
  /// time. Denormalised text — independent of the scammer/person linkage
  /// so it survives even when no profile row exists yet.
  suspectedNameAtSubmit      String?         @map("suspected_name_at_submit")
  createdAt                  DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                  DateTime        @default(now()) @map("updated_at") @db.Timestamptz()
  verifiedAt                 DateTime?       @map("verified_at") @db.Timestamptz()

  scammerId                  String?         @map("scammer_id") @db.Uuid

  reporter User?    @relation(fields: [reporterId], references: [id], onDelete: SetNull)
  scamType ScamType @relation(fields: [scamTypeId], references: [id])
  scammer  Scammer? @relation(fields: [scammerId], references: [id], onDelete: SetNull)

  evidenceFiles    EvidenceFile[]
  moderations      ModerationAction[]
  embedding        ReportEmbedding?
  aiConversations  AiConversation[]
  notifications    Notification[]

  @@index([status, createdAt(sort: Desc)])
  @@index([reporterId, createdAt(sort: Desc)])
  @@index([scamTypeId])
  @@index([scammerId])
  @@map("reports")
}

/// Offender profile — separated from `reports` so the same scammer can be
/// linked to many cases. Identifiers (phone/URL/etc.) live in
/// `scammer_identifiers`; reports keep their `target_identifier*` columns as
/// a denormalised cache.
model Scammer {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayName       String           @map("display_name")
  suspectedName     String?          @map("suspected_name")
  personId          String?          @map("person_id") @db.Uuid
  aliases           String[]         @default([])
  riskLevel         ScammerRiskLevel @default(unknown) @map("risk_level")
  notes             String?
  reportCountCache  Int              @default(0) @map("report_count_cache")
  firstSeenAt       DateTime?        @map("first_seen_at") @db.Timestamptz()
  lastSeenAt        DateTime?        @map("last_seen_at") @db.Timestamptz()
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime         @default(now()) @map("updated_at") @db.Timestamptz()

  person        Person?             @relation(fields: [personId], references: [id], onDelete: SetNull)
  identifiers   ScammerIdentifier[]
  reports       Report[]

  @@index([personId])
  @@map("scammers")
}

/// One real human offender. Many Scammer rows (campaigns / surfaces) may
/// reference the same Person via Scammer.personId. NULL personId on a Scammer
/// = anonymous campaign with no attributed human.
model Person {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName            String           @map("full_name")
  aliases             String[]         @default([])
  riskLevel           ScammerRiskLevel @default(unknown) @map("risk_level")
  notes               String?
  reportCountCache    Int              @default(0) @map("report_count_cache")
  campaignCountCache  Int              @default(0) @map("campaign_count_cache")
  firstSeenAt         DateTime?        @map("first_seen_at") @db.Timestamptz()
  lastSeenAt          DateTime?        @map("last_seen_at") @db.Timestamptz()
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime         @default(now()) @map("updated_at") @db.Timestamptz()

  scammers Scammer[]

  @@index([fullName])
  @@map("persons")
}

/// One scammer can present many surface identifiers (multiple phones, URLs,
/// bank accounts). Unique on (kind, value_normalized) so a phone or URL maps
/// to at most one scammer.
model ScammerIdentifier {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scammerId       String                @map("scammer_id") @db.Uuid
  kind            ScammerIdentifierKind
  valueRaw        String                @map("value_raw")
  valueNormalized String                @map("value_normalized") @db.Citext
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz()

  scammer Scammer @relation(fields: [scammerId], references: [id], onDelete: Cascade)

  @@unique([kind, valueNormalized])
  @@index([scammerId])
  @@map("scammer_identifiers")
}

/// Up to 5 files per report. Bytes live in Supabase Storage. (DESIGN §4.5)
model EvidenceFile {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId    String       @map("report_id") @db.Uuid
  storagePath String       @unique @map("storage_path")
  kind        EvidenceKind
  mimeType    String       @map("mime_type")
  sizeBytes   BigInt       @map("size_bytes")
  uploadedAt  DateTime     @default(now()) @map("uploaded_at") @db.Timestamptz()

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("evidence_files")
}

/// Immutable audit log. Append-only — no UPDATE/DELETE policy is granted to
/// anyone, including admins. (DESIGN §4.6)
model ModerationAction {
  id        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId  String               @map("report_id") @db.Uuid
  adminId   String?              @map("admin_id") @db.Uuid
  action    ModerationActionKind
  remark    String
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz()

  report Report @relation(fields: [reportId], references: [id], onDelete: Restrict)
  admin  User?  @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([reportId, createdAt(sort: Desc)])
  @@map("moderation_actions")
}

/// Gemini gemini-embedding-001 vectors (768-dim) for semantic search. (DESIGN §4.7)
model ReportEmbedding {
  reportId     String                     @id @map("report_id") @db.Uuid
  embedding    Unsupported("vector(768)")
  contentHash  String                     @map("content_hash")
  modelVersion String                     @map("model_version")
  updatedAt    DateTime                   @default(now()) @map("updated_at") @db.Timestamptz()

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_embeddings")
}

/// Admin-published communications. (DESIGN §4.8)
model Announcement {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId      String?              @map("author_id") @db.Uuid
  slug          String               @unique
  title         String
  body          String
  category      AnnouncementCategory
  status        AnnouncementStatus   @default(draft)
  pushedToFcmAt DateTime?            @map("pushed_to_fcm_at") @db.Timestamptz()
  publishedAt   DateTime?            @map("published_at") @db.Timestamptz()
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime             @default(now()) @map("updated_at") @db.Timestamptz()

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)
  attachments    AnnouncementAttachment[]

  @@map("announcements")
}

/// Image or PDF attachment for an announcement. Bytes live in Supabase Storage.
model AnnouncementAttachment {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  announcementId String       @map("announcement_id") @db.Uuid
  storagePath    String       @map("storage_path")
  kind           String
  mimeType       String       @map("mime_type")
  sizeBytes      BigInt       @map("size_bytes")
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@map("announcement_attachments")
}

/// Per-device push tokens (a user may have multiple Android devices). (DESIGN §4.9)
model FcmDevice {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String          @map("user_id") @db.Uuid
  fcmToken   String          @unique @map("fcm_token")
  platform   DevicePlatform?
  appVersion String?         @map("app_version")
  lastSeenAt DateTime        @default(now()) @map("last_seen_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("fcm_devices")
}

/// Persistent inbox of in-app notifications. Source of truth even when an FCM
/// push fails to deliver. (DESIGN §4.9b)
model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  kind      NotificationKind
  title     String
  body      String
  reportId  String?          @map("report_id") @db.Uuid
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

/// Server-side log of every POST /check call. (DESIGN §4.10)
model CheckLog {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?        @map("user_id") @db.Uuid
  inputKind       CheckInputKind @map("input_kind")
  inputNormalized String         @map("input_normalized") @db.Citext
  inputHash       String         @map("input_hash")
  verdict         VerdictLabel
  matchCount      Int            @default(0) @map("match_count")
  latencyMs       Int?           @map("latency_ms")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([inputNormalized, createdAt(sort: Desc)])
  @@map("check_logs")
}

/// Ask AI conversation session. One row per chat. (DESIGN §4.11)
model AiConversation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?   @map("user_id") @db.Uuid
  linkedReportId String?   @map("linked_report_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  lastMessageAt  DateTime  @default(now()) @map("last_message_at") @db.Timestamptz()
  /// In-progress AI-drafted report for this conversation (cross-device sync).
  /// Shape: AskAiPersistedDraft from `@my-product/shared`.
  draftState     Json?     @map("draft_state") @db.JsonB

  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  linkedReport Report?     @relation(fields: [linkedReportId], references: [id], onDelete: SetNull)
  messages     AiMessage[]

  @@index([userId, lastMessageAt(sort: Desc)])
  @@map("ai_conversations")
}

/// Individual turn within an Ask AI conversation. (DESIGN §4.11)
model AiMessage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String
  content        String
  intentDetected Boolean  @default(false) @map("intent_detected")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  conversation AiConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  AiMessageAttachment[]

  @@index([conversationId, createdAt(sort: Asc)])
  @@map("ai_messages")
}

/// File attachment on an Ask AI message. Bytes live in Supabase Storage. (DESIGN §4.11)
model AiMessageAttachment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId   String   @map("message_id") @db.Uuid
  storagePath String   @unique @map("storage_path")
  mimeType    String   @map("mime_type")
  sizeBytes   BigInt   @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  message AiMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("ai_message_attachments")
}

