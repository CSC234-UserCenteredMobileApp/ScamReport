# Copy to .env and fill in real values. .env is gitignored.

PORT=3000

# --- Supabase Postgres (DATABASE_URL is the runtime pooled connection;
#     DIRECT_URL is the direct connection used only by Prisma migrations) ---
DATABASE_URL="postgresql://postgres:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Supabase Storage (and any non-DB Supabase API) ---
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="paste-from-supabase-dashboard"

# --- Firebase Admin SDK ---
# Path to the service-account JSON downloaded from Firebase Console > Project Settings > Service accounts.
# The file itself must NOT be committed (it's gitignored as *service-account*.json).
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# --- Gemini (Google AI Studio) ---
GEMINI_API_KEY="paste-from-aistudio.google.com"
